<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0F1624">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
            <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent" android:tint="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Post New Job" android:textColor="#FFFFFF"
                android:textSize="20sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Job Title *" android:layout_marginBottom="14dp" android:textColorHint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etJobTitle"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Job Description *" android:layout_marginBottom="14dp" android:textColorHint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etJobDesc"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:minLines="3" android:gravity="top" android:textColor="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="Package (LPA)" android:layout_marginEnd="8dp" android:textColorHint="#80FFFFFF">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPackage"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:textColor="#FFFFFF"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="Min CGPA" android:textColorHint="#80FFFFFF">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMinCgpa"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:textColor="#FFFFFF"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="Min 10th %" android:layout_marginEnd="8dp" android:textColorHint="#80FFFFFF">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMinTenth"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:textColor="#FFFFFF"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="Min 12th %" android:textColorHint="#80FFFFFF">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etMinTwelfth"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" android:textColor="#FFFFFF"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Required Skills (comma-separated)" android:layout_marginBottom="14dp" android:textColorHint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etReqSkills"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Allowed Branch (leave blank for all)" android:layout_marginBottom="14dp" android:textColorHint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAllowedBranch"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Location" android:layout_marginBottom="14dp" android:textColorHint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etJobLocation"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Deadline (YYYY-MM-DD)" android:layout_marginBottom="14dp" android:textColorHint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDeadline"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Job Type" android:textColor="#B3FFFFFF" android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinnerJobType" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="@color/colorSurface"
            android:layout_marginBottom="20dp"/>

        <ProgressBar android:id="@+id/progressPost" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:visibility="gone"
            android:layout_gravity="center" android:indeterminateTint="#FFFFFF"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnPostJob"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="🚀 POST JOB" android:textSize="16sp" android:backgroundTint="#4A90E2"/>
    </LinearLayout>
</ScrollView>

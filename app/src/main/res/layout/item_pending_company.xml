<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#3E2723" app:cardCornerRadius="12dp" app:cardElevation="4dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <TextView android:id="@+id/tvPendingCoName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"
            android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvPendingCoIndustry" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#B3FFFFFF"
            android:textSize="13sp" android:layout_marginTop="4dp"/>
        <TextView android:id="@+id/tvPendingCoRecruiter" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FF9800"
            android:textSize="12sp" android:layout_marginTop="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="12dp" android:weightSum="2">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnApprove"
                android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                android:text="Approve" android:layout_marginEnd="8dp"
                android:backgroundTint="#2E7D32" android:textSize="13sp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnReject"
                android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
                android:text="Reject" android:backgroundTint="#C62828" android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>

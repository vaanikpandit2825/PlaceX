<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#14FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvRecJobTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecJobPkg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7C4DFF"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvDriveStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF9800"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRecJobApplicants"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#4CAF50"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRecJobDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF6B6B"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartDrive"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Start Drive"
            android:textAllCaps="false"
            android:backgroundTint="#7C4DFF"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewShortlist"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="View Smart Shortlist"
            android:textAllCaps="false"
            android:layout_marginTop="8dp"
            android:backgroundTint="#00000000"
            android:textColor="#7C4DFF"
            app:strokeColor="#7C4DFF"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScheduleSlots"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Schedule Interviews"
            android:textAllCaps="false"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF9800"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1E2D40"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCandidateRank"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#FFFFFF"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tvCandidateName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCandidateBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvCandidateStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvCandidateCgpa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#4A90E2"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvCandidateSkills"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FF9800"
                android:textSize="12sp"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/pbSkillMatch"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#2D3D50"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShortlistCandidate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Shortlist"
            android:layout_marginTop="10dp"
            android:backgroundTint="#1565C0"
            android:textSize="13sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInterviewCandidate"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Interview"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#FFA000"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectCandidate"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Select"
                android:layout_marginStart="6dp"
                android:backgroundTint="#2E7D32"/>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRejectCandidate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Reject"
            android:layout_marginTop="6dp"
            android:backgroundTint="#D32F2F"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dark_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/bg_glass_card"
            android:tint="#FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Browse Jobs"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />

        <TextView
            android:id="@+id/tvJobCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7C4DFF"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search jobs, companies"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:textColorHint="#80FFFFFF"
        app:boxStrokeColor="#40FFFFFF"
        app:boxCornerRadiusTopStart="18dp"
        app:boxCornerRadiusTopEnd="18dp"
        app:boxCornerRadiusBottomStart="18dp"
        app:boxCornerRadiusBottomEnd="18dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:imeOptions="actionSearch"
            android:padding="14dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All"
            android:checked="true"
            android:textColor="#FFFFFF"
            app:chipBackgroundColor="#14FFFFFF"
            app:chipStrokeColor="#33FFFFFF"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFullTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Time"
            android:textColor="#FFFFFF"
            app:chipBackgroundColor="#14FFFFFF"
            app:chipStrokeColor="#33FFFFFF"
            app:chipStrokeWidth="1dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipIntern"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Internship"
            android:textColor="#FFFFFF"
            app:chipBackgroundColor="#14FFFFFF"
            app:chipStrokeColor="#33FFFFFF"
            app:chipStrokeWidth="1dp" />
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/tvNoJobs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No matching jobs found"
        android:textColor="#66FFFFFF"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvPlacedMsg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You are already placed. Applications are locked."
        android:textColor="#4CAF50"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvJobs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
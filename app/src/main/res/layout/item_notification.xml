<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp"
    android:layout_marginBottom="8dp" android:background="#1E2D40">
    <TextView android:id="@+id/tvNotifMessage" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textColor="#FFFFFF"
        android:textSize="14sp" android:lineSpacingExtra="3dp"/>
    <TextView android:id="@+id/tvNotifTime" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="#80FFFFFF"
        android:textSize="11sp" android:layout_marginTop="6dp"/>
</LinearLayout>
